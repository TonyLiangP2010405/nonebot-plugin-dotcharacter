# nonebot-plugin-dotcharacter 配置示例
# 复制此文件到 your-nonebot-project/.env，修改后重启 NoneBot

# ── LLM Provider ──
# 可选：openai / deepseek / kimi / qwen / zhipu / siliconflow / groq / ollama / custom
DOTCHARACTER_PROVIDER=deepseek
# 自定义 API 地址（provider=custom 时使用）
DOTCHARACTER_API_BASE=https://api.deepseek.com
DOTCHARACTER_API_KEY=sk-your-api-key-here
DOTCHARACTER_MODEL=deepseek-chat

# ── 角色目录 ──
# dot-skill / colleague-skill 输出的 skills 目录路径，逗号分隔
# 留空则自动查找默认位置
DOTCHARACTER_SKILLS_PATH=C:/Users/tghrt/.claude/skills/dot-skill/skills

# ── 对话参数 ──
DOTCHARACTER_MAX_HISTORY=20
DOTCHARACTER_TEMPERATURE=0.8
DOTCHARACTER_MAX_TOKENS=1024
DOTCHARACTER_TIMEOUT=60

# ── 权限 ──
DOTCHARACTER_ADMIN_QQ=703382890
# 允许的群号，逗号分隔。留空表示所有群可用
DOTCHARACTER_ALLOWED_GROUPS=
